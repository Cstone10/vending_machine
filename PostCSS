<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cstone Enterprise - Vending Services</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-900">

  <!-- Header -->
  <header class="bg-blue-900 text-white p-6 shadow-lg">
    <div class="max-w-6xl mx-auto flex justify-between items-center">
      <h1 class="text-2xl font-bold">Cstone Enterprise</h1>
      <nav>
        <a href="#services" class="px-4 hover:underline">Services</a>
        <a href="#reviews" class="px-4 hover:underline">Reviews</a>
        <a href="#contact" class="px-4 hover:underline">Contact</a>
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="text-center py-20 bg-gradient-to-r from-blue-800 to-blue-600 text-white">
    <h2 class="text-4xl font-bold mb-4">Reliable Vending Machine Solutions</h2>
    <p class="text-lg mb-6">Supplying businesses with quality vending machines, snacks, and beverages.</p>
    <a href="#contact" class="bg-yellow-400 text-blue-900 px-6 py-3 rounded-lg font-semibold shadow-md hover:bg-yellow-300">Request Service</a>
  </section>

  <!-- Services -->
  <section id="services" class="max-w-6xl mx-auto py-16 px-6">
    <h3 class="text-3xl font-bold text-center mb-10">Our Services</h3>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-white p-6 rounded-2xl shadow">
        <h4 class="text-xl font-semibold mb-2">Snack Machines</h4>
        <p>Fully stocked snack machines with chips, candy, and healthy options.</p>
      </div>
      <div class="bg-white p-6 rounded-2xl shadow">
        <h4 class="text-xl font-semibold mb-2">Beverage Machines</h4>
        <p>Cold drinks, energy drinks, and water vending solutions for your business.</p>
      </div>
      <div class="bg-white p-6 rounded-2xl shadow">
        <h4 class="text-xl font-semibold mb-2">Custom Stocking</h4>
        <p>Choose your products and we’ll stock them to meet your employees’ needs.</p>
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section id="reviews" class="bg-gray-100 py-16 px-6">
    <h3 class="text-3xl font-bold text-center mb-10">What Our Clients Say</h3>
    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-6">
      <div class="bg-white p-6 rounded-2xl shadow">
        <p class="mb-2">★★★★★</p>
        <p class="italic">"Cstone Enterprise keeps our breakroom fully stocked. Outstanding service!"</p>
        <p class="mt-2 font-semibold">– Sarah M.</p>
      </div>
      <div class="bg-white p-6 rounded-2xl shadow">
        <p class="mb-2">★★★★★</p>
        <p class="italic">"Always reliable and professional. Our employees love the variety."</p>
        <p class="mt-2 font-semibold">– James K.</p>
      </div>
      <div class="bg-white p-6 rounded-2xl shadow">
        <p class="mb-2">★★★★★</p>
        <p class="italic">"Best vending service we’ve ever used. Highly recommend Cstone Enterprise!"</p>
        <p class="mt-2 font-semibold">– Maria R.</p>
      </div>
      <div class="bg-white p-6 rounded-2xl shadow">
        <p class="mb-2">★★★★★</p>
        <p class="italic">"Amazing customer service and top-quality products every time."</p>
        <p class="mt-2 font-semibold">– David L.</p>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <form action="/send" method="POST" class="bg-white p-8 rounded-2xl shadow space-y-4">
  <input type="text" name="business" placeholder="Business Name" class="w-full border p-3 rounded-lg" required>
  <input type="email" name="email" placeholder="Email Address" class="w-full border p-3 rounded-lg" required>
  <input type="tel" name="phone" placeholder="Phone Number" class="w-full border p-3 rounded-lg">
  <textarea name="message" placeholder="Tell us about your vending needs..." rows="4" class="w-full border p-3 rounded-lg" required></textarea>
  <button type="submit" class="bg-blue-800 text-white px-6 py-3 rounded-lg font-semibold shadow hover:bg-blue-700">Submit Request</button>
</form>

  <!-- Footer -->
  <footer class="bg-blue-900 text-white text-center py-6">
    <p>&copy; 2025 Cstone Enterprise. All Rights Reserved.</p>
  </footer>

</body>
</html>
